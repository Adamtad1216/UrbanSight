PORT=5000
NODE_ENV=development

# Database mode: local | atlas | auto
# Use atlas in production deployments such as Render.
DB_MODE=local
DB_NAME=urbansight

# Primary connection URI used by the application.
# For local mode, prefer mongodb://127.0.0.1:27017/urbansight
# For atlas mode, use your Atlas SRV URI.
MONGO_URI=mongodb://127.0.0.1:27017/urbansight

# Optional dedicated Atlas URI used when DB_MODE=atlas or DB_MODE=auto.
# This should be set in production deployments.
MONGO_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Local Mongo host/port + optional auth credentials.
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB_USER=
MONGO_DB_PASSWORD=
MONGO_AUTH_SOURCE=admin

# Optional local fallback when primary URI is unavailable.
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/urbansight

# Retry / pool / timeout hardening.
MONGO_RETRY_ATTEMPTS=8
MONGO_RETRY_INITIAL_DELAY_MS=1000
MONGO_RETRY_MAX_DELAY_MS=30000
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_IDLE_TIME_MS=300000
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Index sync at startup: enabled by default in production and disabled in development.
SYNC_INDEXES_ON_STARTUP=false

# Logging
LOG_LEVEL=info

# Backup / restore tools
BACKUP_DIR=./backups
MONGODUMP_PATH=mongodump
MONGORESTORE_PATH=mongorestore

JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Supports one origin or comma-separated origins.
CLIENT_ORIGIN=http://localhost:5173
# Alternative env name supported for multiple origins.
# CLIENT_ORIGINS=http://localhost:5173,http://localhost:3000
# Render example (web origins only):
# CLIENT_ORIGINS=https://urban-sight-sisx.vercel.app,https://urban-sight.vercel.app
# Native mobile app (Capacitor) origins are allowed by backend CORS helper.
# If you prefer explicit allowlisting, append: http://localhost,https://localhost,capacitor://localhost,ionic://localhost
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alias names also supported for deployment environments.
# CLOUDINARY_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=
# SMTP for staff credential emails
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional OAuth (free Google sign-in for citizen portal)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Optional non-production seed admin user. Leave blank in production.
SEED_ADMIN_EMAIL=admin@urbansight.local
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_PHONE=+251911111111