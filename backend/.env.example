PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/urbansight
MONGO_DB_USER=
MONGO_DB_PASSWORD=
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Supports one origin or comma-separated origins.
CLIENT_ORIGIN=http://localhost:5173
# Alternative env name supported for multiple origins.
# CLIENT_ORIGINS=http://localhost:5173,http://localhost:3000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Alias names also supported for deployment environments.
# CLOUDINARY_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=
# SMTP for staff credential emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=UrbanSight <no-reply@urbansight.local>

# Optional OAuth (free Google/GitHub sign-in for citizen portal)
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

OAUTH_GITHUB_CLIENT_ID=your_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret
OAUTH_GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# Optional non-production seed admin user. Leave blank in production.
SEED_ADMIN_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_PHONE=
SEED_ADMIN_BRANCH=
