PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/urbansight
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Supports one origin or comma-separated origins.
CLIENT_ORIGIN=http://localhost:5173
# Alternative env name supported for multiple origins.
# CLIENT_ORIGINS=http://localhost:5173,http://localhost:3000
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# SMTP for staff credential emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=UrbanSight <no-reply@urbansight.local>
